# Supabase – get from https://supabase.com/dashboard/project/<id>/settings/api
# Use the new key system (sb_publishable_... / sb_secret_...)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# App URL (change to your production domain)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# City config – map center + haversine distances
NEXT_PUBLIC_CITY=Aachen
NEXT_PUBLIC_CITY_LAT=50.7753
NEXT_PUBLIC_CITY_LNG=6.0839

# Mock mode: "true" = hard-coded demo data, no DB writes
# "false" = live Supabase data (required for production)
NEXT_PUBLIC_IS_MOCK=true

# Admin area (/admin) – password for the internal venue/slot entry forms.
# Choose a strong value locally AND in your Vercel project settings.
ADMIN_PASSWORD=change-me
